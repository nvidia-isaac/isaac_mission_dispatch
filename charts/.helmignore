# Patterns to ignore when building packages.
# This supports shell glob matching, relative path matching, and
# negation (prefixed with !). Only one pattern per line.
.DS_Store
# Common VCS dirs
.git/
.gitignore
.bzr/
.bzrignore
.hg/
.hgignore
.svn/
# Common backup files
*.swp
*.bak
*.tmp
*.orig
*~
# Various IDEs
.project
.idea/
*.tmproj
.vscode/
# Any additional values.yaml files, usually patterned with a dash.
values-*.yaml
*.json
*.md
# Exmamples
examples/
# CI Pipeline
.gitlab-ci*
# Remove local charts.
./*.tgz


